{
  "name": "rsstag_front",
  "version": "0.1.0",
  "description": "rsstag frontend app",
  "main": "app.js",
  "type": "module",
  "dependencies": {
    "d3": "^7.9.0",
    "sunburst-chart": "^1.19.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.5",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "babel-loader": "^9.2.1",
    "core-js": "^3.39.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.7.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.82.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.cjs --mode production",
    "build:dev": "webpack --config webpack.config.cjs --mode development",
    "watch": "webpack --config webpack.config.cjs --mode development --watch",
    "dev": "webpack serve --config webpack.dev.config.cjs --mode development --open",
    "clean": "rm -f bundle.js bundle.js.map",
    "lint": "eslint components/context-filter-bar.js components/post-item.js storages/context-filter-storage.js storages/posts-storage.js libs/rsstag_utils.js topics-list.js provider-feeds.js tag-feeds.js post-grouped-snippets.js webpack.config.cjs webpack.dev.config.cjs eslint.config.cjs vitest.config.cjs test/**/*.js --max-warnings=0",
    "lint:all": "eslint \"**/*.{js,jsx,cjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"{apps,components,storages,libs}/**/*.{js,jsx}\" \"*.{js,json,md,cjs}\" \"test/**/*.js\" \"../css/style.scss\"",
    "format:check": "prettier --check \"{apps,components,storages,libs}/**/*.{js,jsx}\" \"*.{js,json,md,cjs}\" \"test/**/*.js\" \"../css/style.scss\"",
    "test": "node --loader ./test/es-module-loader.mjs --test test/**/*.test.js",
    "test:watch": "node --loader ./test/es-module-loader.mjs --test --watch test/**/*.test.js",
    "check": "npm run lint && npm run format:check && npm run build:dev && npm run test"
  },
  "keywords": [
    "rss"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
